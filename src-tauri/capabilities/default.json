{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Allow MQTT communication and window control",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:webview:default",
    "core:window:default",
    "log:default"
  ]
}
