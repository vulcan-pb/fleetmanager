{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HMI_Demo",
  "version": "0.1.0",
  "identifier": "com.hmi.demo",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "./ui"
  },
  "app": {
       "withGlobalTauri": true,   
       "windows": [
      {
        "label": "main",
        "title": "HMI High Legibility",
        "width": 272,
        "height": 480,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
